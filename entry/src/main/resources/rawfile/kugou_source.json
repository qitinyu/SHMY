{
  "name": "酷狗搜索",
  "type": "kg",
  "search": {
    "url": "https://songsearch.kugou.com/song_search_v2",
    "method": "GET",
    "params": {
      "keyword": "{keyword}",
      "page": "1",
      "pagesize": "30",
      "platform": "WebFilter",
      "format": "json"
    },
    "headers": {
      "User-Agent": "Mozilla/5.0"
    },
    "response": {
      "listPath": "data.lists",
      "songId": "FileHash",
      "songName": "SongName",
      "artist": "SingerName",
      "album": "AlbumName",
      "duration": "Duration",
      "coverUrl": "Image",
      "coverPrefix": ""
    }
  },
  "play": {
    "url": "https://wwwapi.kugou.com/yy/index.php",
    "method": "GET",
    "params": {
      "r": "play/getdata",
      "hash": "{songId}"
    },
    "headers": {
      "User-Agent": "Mozilla/5.0",
      "Referer": "https://www.kugou.com/"
    },
    "response": {
      "urlPath": "data.play_url",
      "codePath": "status",
      "successCode": "1"
    }
  },
  "lyric": {
    "url": "https://lyrics.kugou.com/search",
    "method": "GET",
    "params": {
      "ver": "1",
      "man": "yes",
      "client": "pc",
      "hash": "{songId}"
    },
    "response": {
      "listPath": "candidates",
      "timeField": "duration",
      "textField": "id"
    }
  }
}
