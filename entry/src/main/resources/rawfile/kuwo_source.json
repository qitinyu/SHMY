{
  "name": "酷我音乐",
  "type": "kuwo",
  "search": {
    "url": "http://www.kuwo.cn/search/searchMusicBykeyWord",
    "method": "GET",
    "params": {
      "all": "{keyword}",
      "pn": "0",
      "rn": "30",
      "ft": "music",
      "cluster": "0",
      "strategy": "2012",
      "encoding": "utf8",
      "rformat": "json",
      "mobi": "1",
      "issubtitle": "1",
      "show_copyright_off": "1",
      "vipver": "1",
      "client": "kt"
    },
    "headers": {
      "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
    },
    "response": {
      "listPath": "abslist",
      "songId": "MUSICRID",
      "songIdStrip": "MUSIC_",
      "songName": "NAME",
      "artist": "ARTIST",
      "album": "ALBUM",
      "duration": "DURATION",
      "coverUrl": "web_albumpic_short",
      "coverPrefix": "https://img1.kuwo.cn/star/albumcover/300/",
      "isPay": "PAY"
    }
  },
  "play": {
    "url": "https://antiserver.kuwo.cn/anti.s",
    "method": "GET",
    "params": {
      "type": "convert_url3",
      "rid": "{songId}",
      "format": "mp3"
    },
    "response": {
      "urlPath": "url",
      "codePath": "code",
      "successCode": "200"
    }
  },
  "lyric": {
    "url": "https://www.kuwo.cn/openapi/v1/www/lyric/getlyric",
    "method": "GET",
    "params": {
      "musicId": "{songId}"
    },
    "headers": {
      "User-Agent": "Mozilla/5.0",
      "Referer": "https://www.kuwo.cn/"
    },
    "response": {
      "listPath": "data.lrclist",
      "timeField": "time",
      "textField": "lineLyric"
    }
  }
}
